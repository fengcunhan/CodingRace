# 本地开发：docker compose up -d postgres
DATABASE_URL=postgres://codingrace:codingrace@localhost:5432/codingrace

# ip_hash 的盐（生产环境必须换成随机密钥）
IP_HASH_SALT=change-me-in-production

# 会话签名密钥（生产环境必须换成随机密钥，如 openssl rand -hex 32）
AUTH_SECRET=change-me-in-production

# GitHub OAuth App（https://github.com/settings/developers 创建，
# callback 填 <APP_URL>/api/auth/callback）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 站点对外地址（OAuth 回调与安装指引使用）
APP_URL=http://localhost:3000
